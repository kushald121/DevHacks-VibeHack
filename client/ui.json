{
    "project": {
        "name": "Your Coffee Pal",
        "type": "Editorial Podcast Website",
        "description": "A podcast website about coffee culture, featuring baristas and coffee shop owners",
        "theme": "editorial-dark",
        "language": "en"
    },
    "design_tokens": {
        "colors": {
            "primary": {
                "yellow": "#F5C800",
                "yellow_dark": "#D4A800",
                "yellow_bar": "#F5C800"
            },
            "neutrals": {
                "black": "#0A0A0A",
                "dark_bg": "#111111",
                "card_bg": "#1A1A1A",
                "overlay_dark": "rgba(0, 0, 0, 0.55)",
                "overlay_gradient": "linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.2) 60%, transparent 100%)",
                "white": "#FFFFFF",
                "white_70": "rgba(255,255,255,0.70)",
                "white_50": "rgba(255,255,255,0.50)",
                "white_30": "rgba(255,255,255,0.30)"
            },
            "text": {
                "primary": "#FFFFFF",
                "secondary": "rgba(255,255,255,0.70)",
                "muted": "rgba(255,255,255,0.45)",
                "on_yellow": "#0A0A0A"
            }
        },
        "typography": {
            "fonts": {
                "display_script": {
                    "family": "Dancing Script, Pacifico, cursive",
                    "google_import": "https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&display=swap",
                    "usage": "Hero headline, episode names, logo wordmark",
                    "notes": "Mimics the hand-lettered script style visible in the design for 'Your Coffee Pal', 'Kenji Matsunaga', 'Ben and Samantha', etc."
                },
                "body_sans": {
                    "family": "DM Sans, sans-serif",
                    "google_import": "https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap",
                    "usage": "Navigation links, body copy, labels, episode descriptions"
                },
                "mono": {
                    "family": "JetBrains Mono, monospace",
                    "usage": "Duration timestamp, version strings"
                }
            },
            "scale": {
                "logo": {
                    "size": "36px",
                    "weight": "700",
                    "lineHeight": "1.0",
                    "font": "display_script"
                },
                "hero_name": {
                    "size": "clamp(56px, 8vw, 110px)",
                    "weight": "700",
                    "lineHeight": "0.95",
                    "font": "display_script"
                },
                "section_title": {
                    "size": "clamp(36px, 5vw, 64px)",
                    "weight": "700",
                    "font": "display_script"
                },
                "card_name": {
                    "size": "clamp(28px, 3.5vw, 48px)",
                    "weight": "700",
                    "font": "display_script"
                },
                "nav_link": {
                    "size": "12px",
                    "weight": "400",
                    "letterSpacing": "0.04em",
                    "font": "body_sans"
                },
                "section_label": {
                    "size": "11px",
                    "weight": "600",
                    "letterSpacing": "0.12em",
                    "textTransform": "uppercase",
                    "font": "body_sans"
                },
                "episode_title": {
                    "size": "14px",
                    "weight": "500",
                    "font": "body_sans"
                },
                "body": {
                    "size": "13px",
                    "weight": "400",
                    "lineHeight": "1.7",
                    "font": "body_sans"
                },
                "meta": {
                    "size": "11px",
                    "weight": "400",
                    "color": "white_50",
                    "font": "body_sans"
                },
                "timestamp": {
                    "size": "13px",
                    "weight": "500",
                    "font": "mono"
                },
                "cta_button": {
                    "size": "12px",
                    "weight": "600",
                    "letterSpacing": "0.06em",
                    "font": "body_sans"
                }
            }
        },
        "spacing": {
            "xs": "4px",
            "sm": "8px",
            "md": "16px",
            "lg": "24px",
            "xl": "40px",
            "2xl": "64px",
            "3xl": "96px",
            "page_padding_x": "clamp(24px, 5vw, 80px)"
        },
        "border_radius": {
            "sm": "4px",
            "md": "8px",
            "lg": "12px",
            "pill": "999px"
        },
        "shadows": {
            "card": "0 8px 32px rgba(0,0,0,0.5)",
            "button": "0 4px 16px rgba(0,0,0,0.3)",
            "text_shadow": "0 2px 16px rgba(0,0,0,0.6)"
        },
        "sidebar": {
            "width": "32px",
            "background": "#F5C800",
            "text_color": "#0A0A0A",
            "font_size": "10px",
            "font_weight": "700",
            "letter_spacing": "0.18em",
            "text_transform": "uppercase",
            "writing_mode": "vertical-rl",
            "text_orientation": "mixed",
            "labels": {
                "top": "EDITORIAL",
                "bottom": "DESIGN EXPLORATION"
            }
        }
    },
    "layout": {
        "type": "magazine-editorial",
        "structure": "left-sidebar + main-content",
        "sidebar": {
            "position": "fixed-left",
            "width": "32px",
            "full_height": true,
            "background": "yellow",
            "contains": [
                "sidebar_labels"
            ]
        },
        "main": {
            "margin_left": "32px",
            "display": "grid",
            "sections": [
                "navigation",
                "hero",
                "latest_episodes",
                "side_panel"
            ]
        },
        "grid": {
            "main_layout": "hero-left + side-panel-right",
            "hero_width": "62%",
            "side_panel_width": "38%",
            "breakpoints": {
                "mobile": "< 768px",
                "tablet": "768px - 1024px",
                "desktop": "> 1024px"
            }
        }
    },
    "components": {
        "sidebar_label": {
            "type": "fixed-vertical-bar",
            "position": "left",
            "width": "32px",
            "height": "100vh",
            "background": "#F5C800",
            "items": [
                {
                    "text": "EDITORIAL",
                    "position": "top",
                    "padding_top": "24px"
                },
                {
                    "text": "DESIGN EXPLORATION",
                    "position": "bottom",
                    "padding_bottom": "24px"
                }
            ],
            "text_style": {
                "font": "body_sans",
                "size": "10px",
                "weight": "700",
                "color": "#0A0A0A",
                "letter_spacing": "0.18em",
                "writing_mode": "vertical-rl"
            }
        },
        "navigation": {
            "type": "horizontal-navbar",
            "position": "absolute",
            "z_index": 100,
            "background": "transparent",
            "padding": "20px 32px",
            "layout": "logo | nav-groups | cta-button",
            "logo": {
                "type": "wordmark",
                "text": "Your\nCoffee\nPal",
                "font": "display_script",
                "size": "28px",
                "color": "#FFFFFF",
                "line_height": "1.1",
                "multiline": true
            },
            "nav_groups": [
                {
                    "id": "group_1",
                    "items": [
                        {
                            "label": "HOME",
                            "href": "/"
                        },
                        {
                            "label": "PODCASTS",
                            "href": "/podcasts"
                        },
                        {
                            "label": "MAGAZINE",
                            "href": "/magazine"
                        },
                        {
                            "label": "EVENTS",
                            "href": "/events"
                        }
                    ]
                },
                {
                    "id": "group_2",
                    "items": [
                        {
                            "label": "HANGOUT",
                            "href": "/hangout"
                        },
                        {
                            "label": "GUIDEBOOK",
                            "href": "/guidebook"
                        },
                        {
                            "label": "MERCH",
                            "href": "/merch"
                        },
                        {
                            "label": "MARKETPLACE",
                            "href": "/marketplace"
                        }
                    ]
                },
                {
                    "id": "group_3",
                    "items": [
                        {
                            "label": "ABOUT US",
                            "href": "/about"
                        },
                        {
                            "label": "PRESS RELEASE",
                            "href": "/press"
                        },
                        {
                            "label": "CONTACT",
                            "href": "/contact"
                        }
                    ]
                }
            ],
            "nav_link_style": {
                "font": "body_sans",
                "size": "11px",
                "weight": "400",
                "color": "rgba(255,255,255,0.80)",
                "letter_spacing": "0.05em",
                "hover_color": "#FFFFFF",
                "text_transform": "uppercase",
                "display": "block",
                "line_height": "1.8"
            },
            "cta_button": {
                "label": "Be a Contributor",
                "href": "/contribute",
                "style": {
                    "background": "transparent",
                    "border": "1px solid rgba(255,255,255,0.6)",
                    "border_radius": "999px",
                    "padding": "8px 20px",
                    "font": "body_sans",
                    "size": "11px",
                    "weight": "500",
                    "color": "#FFFFFF",
                    "hover_background": "#FFFFFF",
                    "hover_color": "#0A0A0A",
                    "transition": "all 0.25s ease"
                }
            }
        },
        "hero_section": {
            "type": "full-bleed-hero",
            "height": "100vh",
            "min_height": "700px",
            "position": "relative",
            "overflow": "hidden",
            "background": {
                "type": "image",
                "description": "Dark moody photograph of a barista working in a coffee shop — cinematic, desaturated",
                "placeholder_color": "#1A1414",
                "overlay": "linear-gradient(to top, rgba(0,0,0,0.90) 0%, rgba(0,0,0,0.40) 50%, rgba(0,0,0,0.20) 100%)",
                "object_fit": "cover",
                "object_position": "center top"
            },
            "featured_episode_badge": {
                "display": false,
                "notes": "No visible badge in the design; the name acts as the focus"
            },
            "intro_text": {
                "position": "bottom-left",
                "max_width": "320px",
                "content": {
                    "column_1": "Today, we're sitting down with Kenji Matsunaga, the head barista at Haru Brew Tokyo, a cozy café known for its slow mornings and hand-crafted espresso. Kenji shares his journey from a curious coffee drinker to a barista who treats every cup as a conversation — between beans, water, and time.",
                    "column_2": "From experimenting with light roasts to curating seasonal blends, Kenji sees coffee as both science and art. In our chat, he opens up about the small rituals that keep him inspired, the challenge of balancing precision with passion, and the quiet joy of seeing someone's first sip turn into a smile."
                },
                "style": {
                    "font": "body_sans",
                    "size": "13px",
                    "color": "rgba(255,255,255,0.75)",
                    "line_height": "1.7",
                    "columns": 2,
                    "column_gap": "32px"
                }
            },
            "hero_name": {
                "type": "large-script-overlay",
                "text": "Kenji\nMatsunaga",
                "position": "center-bottom-left",
                "style": {
                    "font": "display_script",
                    "size": "clamp(64px, 9vw, 120px)",
                    "color": "#FFFFFF",
                    "line_height": "0.92",
                    "text_shadow": "0 4px 32px rgba(0,0,0,0.5)",
                    "z_index": 10
                }
            },
            "watch_button": {
                "label": "Watch Now",
                "duration": "30:48",
                "icon": "play_triangle",
                "position": "bottom-center-right of text columns",
                "style": {
                    "background": "#FFFFFF",
                    "color": "#0A0A0A",
                    "border_radius": "999px",
                    "padding": "12px 24px",
                    "font": "body_sans",
                    "size": "13px",
                    "weight": "600",
                    "display": "flex",
                    "align_items": "center",
                    "gap": "12px",
                    "duration_style": {
                        "font": "mono",
                        "size": "13px",
                        "opacity": 0.6
                    },
                    "play_icon": {
                        "shape": "triangle",
                        "size": "10px",
                        "color": "#0A0A0A"
                    },
                    "hover": {
                        "background": "#F5C800",
                        "color": "#0A0A0A"
                    },
                    "transition": "all 0.25s ease"
                }
            }
        },
        "latest_episodes_section": {
            "type": "horizontal-scroll-cards",
            "label": "LATEST EPISODES",
            "label_style": {
                "font": "body_sans",
                "size": "11px",
                "weight": "600",
                "letter_spacing": "0.14em",
                "color": "rgba(255,255,255,0.55)",
                "text_transform": "uppercase",
                "margin_bottom": "20px"
            },
            "padding": "48px 0",
            "background": "#0A0A0A",
            "navigation_arrows": {
                "type": "circle-buttons",
                "left_icon": "←",
                "right_icon": "→",
                "style": {
                    "width": "36px",
                    "height": "36px",
                    "border": "1px solid rgba(255,255,255,0.25)",
                    "border_radius": "50%",
                    "background": "transparent",
                    "color": "#FFFFFF",
                    "font_size": "14px",
                    "hover_background": "#FFFFFF",
                    "hover_color": "#0A0A0A"
                }
            },
            "card_grid": {
                "display": "flex",
                "gap": "20px",
                "overflow_x": "auto",
                "scroll_behavior": "smooth",
                "scrollbar": "hidden"
            },
            "episode_card": {
                "type": "image-overlay-card",
                "width": "clamp(220px, 22vw, 300px)",
                "aspect_ratio": "3/4",
                "border_radius": "8px",
                "overflow": "hidden",
                "cursor": "pointer",
                "image": {
                    "type": "photo",
                    "description": "Portrait photo of barista/coffee shop owner in their space",
                    "object_fit": "cover",
                    "width": "100%",
                    "height": "100%",
                    "filter": "brightness(0.75)"
                },
                "overlay": {
                    "type": "gradient",
                    "background": "linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.1) 60%, transparent 100%)"
                },
                "content": {
                    "position": "absolute",
                    "bottom": "0",
                    "left": "0",
                    "right": "0",
                    "padding": "20px 16px",
                    "episode_name": {
                        "type": "script-text",
                        "font": "display_script",
                        "size": "clamp(24px, 3vw, 38px)",
                        "color": "#FFFFFF",
                        "line_height": "1.0",
                        "margin_bottom": "6px"
                    },
                    "episode_title": {
                        "font": "body_sans",
                        "size": "13px",
                        "weight": "500",
                        "color": "#FFFFFF",
                        "margin_bottom": "4px"
                    },
                    "episode_meta": {
                        "font": "body_sans",
                        "size": "11px",
                        "color": "rgba(255,255,255,0.55)"
                    }
                },
                "hover_effect": {
                    "transform": "scale(1.02)",
                    "filter": "brightness(0.9)",
                    "transition": "all 0.3s ease"
                }
            },
            "episodes_data": [
                {
                    "id": "ep_001",
                    "name": "Ben and\nSamantha",
                    "title": "Building Coffee Shop: Relationship and Business",
                    "meta": "Ben Wise and Samantha William — Coffee Shop Owner",
                    "image_description": "Two people smiling in front of a coffee shop counter with warm lighting"
                },
                {
                    "id": "ep_002",
                    "name": "Daniel",
                    "title": "Cups & Conversations",
                    "meta": "Daniel Summer — Barista",
                    "image_description": "Person in a hat and apron smiling in a coffee shop"
                },
                {
                    "id": "ep_003",
                    "name": "Thomas",
                    "title": "Daily Cup of Happiness",
                    "meta": "Thomas Book — Barista",
                    "image_description": "Smiling man wearing a beanie and apron"
                }
            ]
        },
        "side_panel": {
            "type": "right-panel-grid",
            "width": "38%",
            "position": "right",
            "background": "#0A0A0A",
            "display": "grid",
            "grid_rows": "1fr 1fr 1fr",
            "gap": "0px",
            "sections": [
                {
                    "id": "featured_episodes_row",
                    "type": "two-column-episode-cards",
                    "height": "40%",
                    "display": "grid",
                    "columns": 2,
                    "gap": "0px",
                    "cards": [
                        {
                            "id": "side_ep_001",
                            "name": "Ben and\nSamantha",
                            "title": "Building Coffee Shop: Relationship and Business",
                            "meta": "Ben Wise and Samantha William — Coffee Shop Owner",
                            "image_description": "Two baristas smiling warmly in coffee shop",
                            "card_style": {
                                "position": "relative",
                                "overflow": "hidden",
                                "aspect_ratio": "1/1"
                            },
                            "overlay": "linear-gradient(to top, rgba(0,0,0,0.80) 0%, transparent 60%)"
                        },
                        {
                            "id": "side_ep_002",
                            "name": "Daniel\nSummer",
                            "title": "Cups & Conversations",
                            "meta": "Daniel Summer — Barista",
                            "image_description": "Barista in a cap in warm coffee shop environment",
                            "card_style": {
                                "position": "relative",
                                "overflow": "hidden",
                                "aspect_ratio": "1/1"
                            },
                            "overlay": "linear-gradient(to top, rgba(0,0,0,0.80) 0%, transparent 60%)"
                        }
                    ]
                },
                {
                    "id": "merch_row",
                    "type": "merchandise-showcase",
                    "height": "33%",
                    "display": "grid",
                    "columns": 2,
                    "gap": "0px",
                    "background": "#111111",
                    "products": [
                        {
                            "id": "merch_tshirt_white",
                            "type": "t-shirt",
                            "color": "white",
                            "label": "Your Coffee Pal — A Podcast About Coffee",
                            "image_description": "White t-shirt with Your Coffee Pal logo printed on chest",
                            "background": "#ECECEC"
                        },
                        {
                            "id": "merch_tshirt_black",
                            "type": "t-shirt",
                            "color": "black",
                            "label": "Your Coffee Pal — A Podcast About Coffee",
                            "image_description": "Black t-shirt with Your Coffee Pal logo printed on chest, person in background",
                            "background": "#2A2A2A"
                        }
                    ]
                },
                {
                    "id": "brand_logo_row",
                    "type": "brand-identity-block",
                    "height": "27%",
                    "background": "#0A0A0A",
                    "display": "flex",
                    "flex_direction": "column",
                    "align_items": "center",
                    "justify_content": "center",
                    "padding": "32px",
                    "logo": {
                        "type": "large-wordmark",
                        "text": "Your\nCoffee\nPal",
                        "font": "display_script",
                        "size": "clamp(48px, 6vw, 80px)",
                        "color": "#FFFFFF",
                        "line_height": "0.95",
                        "text_align": "center"
                    },
                    "tagline": {
                        "text": "A PODCAST ABOUT COFFEE",
                        "font": "body_sans",
                        "size": "11px",
                        "weight": "600",
                        "letter_spacing": "0.20em",
                        "color": "rgba(255,255,255,0.60)",
                        "text_transform": "uppercase",
                        "margin_top": "16px"
                    }
                }
            ]
        }
    },
